<Window x:Class="PaintApp.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор цвета" Height="220" Width="320" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="15">
        <TextBlock Text="Выберите цвет для рисования:" FontWeight="Bold" Margin="0,0,0,10"/>
        <WrapPanel HorizontalAlignment="Center">
            <Button Content="Черный" Background="Black" Foreground="White" Width="90" Height="35" Margin="5" Click="ColorButton_Click" Tag="Black"/>
            <Button Content="Красный" Background="Red" Foreground="White" Width="90" Height="35" Margin="5" Click="ColorButton_Click" Tag="Red"/>
            <Button Content="Зеленый" Background="Green" Foreground="White" Width="90" Height="35" Margin="5" Click="ColorButton_Click" Tag="Green"/>
            <Button Content="Синий" Background="Blue" Foreground="White" Width="90" Height="35" Margin="5" Click="ColorButton_Click" Tag="Blue"/>
            <Button Content="Желтый" Background="Yellow" Width="90" Height="35" Margin="5" Click="ColorButton_Click" Tag="Yellow"/>
            <Button Content="Белый" Background="White" Width="90" Height="35" Margin="5" Click="ColorButton_Click" Tag="White"/>
        </WrapPanel>
        <Button Content="Отмена" Width="100" Height="30" Margin="0,15,0,0" HorizontalAlignment="Right" IsCancel="True"/>
    </StackPanel>
</Window>